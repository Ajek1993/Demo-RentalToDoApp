# =============================================
# Zmienne środowiskowe aplikacji (frontend)
# =============================================
# Skopiuj ten plik jako .env i uzupełnij wartości:
#   cp .env.example .env

# Supabase - adres URL projektu
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase - klucz publiczny (anon key)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# VAPID - klucz publiczny do Web Push notifications
# Wygeneruj parę kluczy: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key

# =============================================
# Sekrety Edge Function (ustawiać w Supabase Dashboard)
# Dashboard → Settings → Edge Functions → Secrets
# =============================================
# VAPID_PUBLIC_KEY=your_vapid_public_key
# VAPID_PRIVATE_KEY=your_vapid_private_key
# VAPID_EMAIL=mailto:admin@example.com
# SUPABASE_URL (ustawiane automatycznie przez Supabase)
# SUPABASE_SERVICE_ROLE_KEY (ustawiane automatycznie przez Supabase)
